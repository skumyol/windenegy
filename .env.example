# Example environment configuration for Windenegy
# Copy this to .env and customize for your environment

# Environment
WINDENEGY_ENV=development
WINDENEGY_DEBUG=true

# Data paths
WINDENEGY_DATA_RAW_PATH=data/raw
WINDENEGY_DATA_INTERIM_PATH=data/interim
WINDENEGY_DATA_PROCESSED_PATH=data/processed

# Model artifacts
WINDENEGY_MODEL_ARTIFACTS_PATH=artifacts/models
WINDENEGY_MODEL_METRICS_PATH=artifacts/metrics
WINDENEGY_MODEL_REPORTS_PATH=artifacts/reports

# API settings
WINDENEGY_API_HOST=0.0.0.0
WINDENEGY_API_PORT=8000
WINDENEGY_API_RELOAD=true
WINDENEGY_API_LOG_LEVEL=debug

# Dashboard settings
WINDENEGY_DASHBOARD_PORT=8501
WINDENEGY_DASHBOARD_API_URL=http://localhost:8000

# Weather provider (null, openmeteo, era5)
WINDENEGY_WEATHER_PROVIDER=null

# Logging
WINDENEGY_LOG_LEVEL=DEBUG
WINDENEGY_LOG_FORMAT=console
